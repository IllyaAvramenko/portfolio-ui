new file mode 100644
index 0000000..d51ddad
--- /dev/null
+++ b/src/i18n/i18n.ts
@@ -0,0 +1,20 @@
+import i18n from 'i18next';
+import { initReactI18next } from 'react-i18next';
+import en from './en.json';
+import ua from './ua.json';
+
+i18n
+  .use(initReactI18next)
+  .init({
+    fallbackLng: 'ua',
+    lng: 'ua',
+    resources: {
+        en: { translation : en},
+        ua: { translation : ua}
+    },
+    interpolation: {
+      escapeValue: false,
+    }
+  });
+
+export default i18n;
